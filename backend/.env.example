APP_NAME=ThirdAI Video Annotation Platform
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/video_annotations
REDIS_URL=redis://redis:6379/0
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=video-assets
S3_REGION=us-east-1
S3_USE_SSL=false
S3_FORCE_PATH_STYLE=true
UPLOAD_PART_SIZE_MB=10
PRESIGNED_URL_TTL_SECONDS=86400
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
CORS_ORIGINS=http://localhost:5173
FRONTEND_BASE_URL=http://localhost:5173
OPENAI_API_KEY=
OPENAI_SUMMARY_MODEL=gpt-4.1-nano
OPENAI_SUMMARY_TIMEOUT_SECONDS=8
